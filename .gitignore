# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Secrets — never commit
.env
.env.*
!.env.example

# Datasets & processed assets (rebuild locally or from Drive/zip)
data/raw/**
!data/raw/**/
!data/raw/**/.gitkeep

data/processed/**
!data/processed/**/
!data/processed/**/.gitkeep

# Checkpoints & training runs (keep only placeholder .gitkeep dirs if present)
experiments/**
!experiments/**/
!experiments/**/.gitkeep

# Weight / archive blobs (also covered under experiments/, but catch strays)
*.pdparams
*.pdopt
*.states
*.tar
*.tar.gz
*.zip

# PaddleOCR clone — install per machine / Colab; do not vendor
PaddleOCR/

wandb/

# OS/editor
.DS_Store
Thumbs.db
